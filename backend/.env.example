APP_CONFIG_FILE=
HOST=
PORT=8000
LOG_LEVEL=info

LLAMACTL_BASE_URL=http://localhost:8080
LLAMACTL_MANAGEMENT_API_KEY=replace-with-real-key

APP_JWT_SIGNING_KEY=replace-with-long-random-secret
APP_JWT_ACCESS_TTL=15m
APP_JWT_REFRESH_TTL=168h
APP_STORAGE_BACKEND=inmemory
APP_STORAGE_SQLITE_PATH=data/llamactl-console.db

BOOTSTRAP_ADMIN_USERNAME=admin
BOOTSTRAP_ADMIN_PASSWORD=

HTTP_READ_TIMEOUT=10s
HTTP_WRITE_TIMEOUT=15s
HTTP_IDLE_TIMEOUT=60s
HTTP_SHUTDOWN_TIMEOUT=10s
